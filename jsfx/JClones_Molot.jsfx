);

// compression part of transfer function
function EnvelopeClip_h2(x) local(y, pow_x_ratio, x2, x4)
(
  (this.ratio > 0.0) ? (
    // y = pow(x / this.thresh, this.ratio) * this.thresh;

    (x > M_SQRT_k[this.ratio_index][9]) ? (
      x = M_SQRT_k[this.ratio_index][9];
    );

    // x ^ this.ratio

    x2 = x * x;
    x4 = x2 * x2;

    pow_x_ratio = M_SQRT_k[this.ratio_index][0] +
      x * M_SQRT_k[this.ratio_index][1] + x2 * M_SQRT_k[this.ratio_index][2] + x2 * x * M_SQRT_k[this.ratio_index][3] +
      x4 * M_SQRT_k[this.ratio_index][4] + x4 * x * M_SQRT_k[this.ratio_index][5] + x4 * x2 * M_SQRT_k[this.ratio_index][6] +
      x4 * x2 * x * M_SQRT_k[this.ratio_index][7] + x4 * x4 * M_SQRT_k[this.ratio_index][8];

    y = pow_x_ratio * this.thresh_ratio;

  ) : (
    // hardlimit compression part
    y = this.thresh;
  );

  y;
);

// dh2(x)/dx  (used for h1 smoothing)
function EnvelopeClip_dh2(x) local(y)
(
  (this.ratio > 0.0) ? (
    // logarithmic compression part
    (x > 0.0) ? (
      // y = pow(x / this.thresh, this.ratio) * this.thresh * this.ratio / x;
      y = this.EnvelopeClip_h2(x) * this.ratio / x;

    ) : (
      y = 0.0;
    );

  ) : (
    // hardlimit compression part
    y = 0.0;
  );

  y;
);

// knee part of transfer function
function EnvelopeClip_h1(x) local(x2, x3, x4)
(
  x2 = x * x;
  x3 = x2 * x;
  x4 = x2 * x2;

  x + x3 * this.A3 + x4 * this.A4;
);

// transfer function
function EnvelopeClip_h(x) local(y)
(
  y = (x < this.thresh2) ? this.EnvelopeClip_h1(x) : this.EnvelopeClip_h2(x);

  y;
);
function EnvelopeClip_getGR(x) local(y)
(
  y = (x >= this.hx_min) ? this.EnvelopeClip_h(x) / x : 1.0;

  y;
);

function EnvelopeClip_setThreshold(thresh, knee, ratio) local(delta, x2, y2, dy2)
(
  this.thresh = thresh;
  this.hx_min = 0.000001;  // GR(this.hx_min) = 1

  // calculate h2 info (compression part)
  (ratio <= 10.9) ? (
    // logarithmic ratio (only 1.1..10.9 supported)
    ratio = floor(ratio * 10.0) / 10.0;
    this.ratio_index = (ratio * 10.0 - 11.0);

    this.ratio = 1.0 / ratio;

    (this.ratio_index < 0) ? this.ratio_index = 0;
    (this.ratio_index >= 99) ? this.ratio_index = 98;

    this.thresh_ratio = pow(1.0 / this.thresh, this.ratio) * this.thresh;

  ) : (
    // limiter mode
    this.ratio = 0;
  );

  delta = (1.0 - knee * 0.95) * this.thresh;  // this.thresh - soft knee

  this.thresh2 = this.thresh + delta;

  // calculate h1 (soft knee part)
  x2 = this.thresh2;
  y2 = this.EnvelopeClip_h2(x2);
  dy2 = this.EnvelopeClip_dh2(x2);

  // calculate this.A[]  (this.A[0] = 0, this.A[1] = 1, this.A[2] = 0)
  this.A3 = -(3.0 * x2 - 4.0 * y2 + x2 * dy2) / (x2 * x2 * x2);
  this.A4 = 1.0 / (x2 * x2 * x2 * x2) * (2.0 * x2 - 3.0 * y2 + x2 * dy2);

);

function EnvelopeClip_processSample(x)
(
  // check bypass
  (this.ratio == 1.0) ? 1.0 : this.EnvelopeClip_getGR(x);
);

/*
 * Saturator
 */

function Saturator_saturate8(x) local(x2, x4, y)
(
  // clip
  (x < -1.927384823613229) ? (
    x = -1.927384823613229;
  );
  (x > 1.925547073273503) ? (
    x = 1.925547073273503;
  );

  // calculate polynome
  x2 = x * x;
  x4 = x2 * x2;

  y = 1.043653138515045 * x + 0.051012188210767 * x2 + -0.048182108389193 * x2 * x +
    -0.076851680685586 * x4 + -0.076851680685586 * x4 * x + 0.019456557521838 * x4 * x2 +
    0.011322488095808 * x4 * x2 * x + -0.001614452827801 * x4 * x4;

  y;
);

function Saturator_processSample(x)
(
  // sat8 sounds better
  Saturator_saturate8(x / this.threshold) * this.threshold;
);

function Saturator_setThreshold(threshold)
(
  this.threshold = threshold;
);

/*
 * ChannelCompressor
 */

function ChannelCompressor_preprocessSample(x) local(x_sc)
(
  (this.use_sidechain_flt) ? (
    // use filter#1 (user-defined high-pass)
    x_sc = this.sidechain_flt.LowShelfPhon80_processSample(x);
  ) : (
    // use filter#2 (hardcoded shelf)
    x_sc = this.sidechain_flt2.Filter2_processSample(x);
  );

  this.env.AREnvelope_processSampleAC(x_sc * this.in_gain) * this.detector_fix;
);

// compress, saturate and feed limiter detector
function ChannelCompressor_postprocessSample(x_dry, env) local(env_gr, env_ar, x_wet, y)
(
  // #3. generate GR envelope by threshold & ratio
  env_gr = this.envelope_k.EnvelopeClip_processSample(env);

  // #4. apply attack/release to env_gr
  // reverse because GR curve is reverse: rotate around 1.0
  env_ar = 2.0 - this.env_ar.AREnvelope_processSampleDC(2.0 - env_gr);

  this.gr = env_ar;

  // #5. apply gain reduction to dry input
  x_wet = x_dry * env_ar * this.in_gain;

  (this.use_saturator) ? (
    // saturate compressor output for please
    x_wet = this.saturator.Saturator_processSample(x_wet);
  );

  // #6. makeup gain & dry mix
  y = x_wet * this.gain * (1.0 - this.dry_mix_k) + x_dry * this.dry_mix_k;

  y;
);

function ChannelCompressor_processSample(x, sc)
(
  this.ChannelCompressor_postprocessSample(x, this.ChannelCompressor_preprocessSample(sc));
);

function ChannelCompressor_reset()
(
  this.env.AREnvelope_reset();
  this.sidechain_flt.LowShelfPhon80_reset();
  this.sidechain_flt2.Filter2_reset();
  this.env_ar.AREnvelope_reset(1);
);

/*
 * StereoCompressor
 */

SL_MONO = 0;
SL_2MONO = 1;
SL_M = 2;
SL_S = 3;
SL_MS = 4;
SL_STEREO = 5;

function StereoCompressor_setEnvelope(attack_s, release_s, sidechain_freq, sharp_mode) local(env_attack, env_release, max_freq)
(
  (!sharp_mode) ? (
    (attack_s <= 0.0095) ? (
      // use fast detector
      env_attack = 0.001;   // 1ms
      env_release = 0.050;  // 50ms

      this.comp1.detector_fix = DB_TO_K(0.547);  // calibrated by 1kHz
      this.comp2.detector_fix = this.comp1.detector_fix;

    ) : (attack_s <= 0.0245) ? (
      // use slow detector
      env_attack = 0.010;   // 10ms
      env_release = 0.050;  // 50ms

      this.comp1.detector_fix = DB_TO_K(1.536);  // calibrated by 1kHz
      this.comp2.detector_fix = this.comp1.detector_fix;

    ) : (
    // use the slowest detector
      env_attack = 0.025;   // 25ms
      env_release = 0.050;  // 50ms

      this.comp1.detector_fix = DB_TO_K(2.237);  // calibrated by 1kHz
      this.comp2.detector_fix = this.comp1.detector_fix;

    );
  ) : (
    // use the fastest detector
    env_attack = 0.00005;   // 0.1ms
    env_release = 0.001;  // 1ms

    this.comp1.detector_fix = DB_TO_K(0.878);  // calibrated by 1kHz
    this.comp2.detector_fix = this.comp1.detector_fix;
  );

  max_freq = 21500.0;

  this.comp1.env.AREnvelope_setAttackRelease(AREnvelope_sec_to_freq_k(env_attack), AREnvelope_sec_to_freq_k(env_release), max_freq / srate, 0);
  this.comp2.env.AREnvelope_setAttackRelease(AREnvelope_sec_to_freq_k(env_attack), AREnvelope_sec_to_freq_k(env_release), max_freq / srate, 0);

  // sidechain highpass
  (sidechain_freq > 0.0) ? (
    this.comp1.sidechain_flt.LowShelfPhon80_setFilter(sidechain_freq);
    this.comp1.use_sidechain_flt = 1;

    this.comp2.sidechain_flt.LowShelfPhon80_setFilter(sidechain_freq);
    this.comp2.use_sidechain_flt = 1;
  ) : (
    // use hardcoded lowshelf
    this.comp1.sidechain_flt2.Filter2_LSFilter2(296.0 / srate, 0.7, DB_TO_K(-3.02));
    this.comp1.use_sidechain_flt = 0;

    this.comp2.sidechain_flt2.Filter2_LSFilter2(296.0 / srate, 0.7, DB_TO_K(-3.02));
    this.comp2.use_sidechain_flt = 0;
  );

  // setup A/R envelopes

  this.comp1.env_ar.AREnvelope_setAttackRelease(
    AREnvelope_sec_to_freq_k(attack_s),
    AREnvelope_sec_to_freq_k(release_s),
    max_freq / srate,
    sharp_mode);   // if (!sharp_mode) got S-curve; else exp-curve;

  this.comp2.env_ar.AREnvelope_setAttackRelease(
    AREnvelope_sec_to_freq_k(attack_s),
    AREnvelope_sec_to_freq_k(release_s),
    max_freq / srate,
    sharp_mode);   // if (!sharp_mode) got S-curve; else exp-curve;
);

function StereoCompressor_setEnvelopeK(threshold, knee, ratio)
(
  // setup gain clipper
  this.comp1.envelope_k.EnvelopeClip_setThreshold(threshold, knee, ratio);
  this.comp2.envelope_k.EnvelopeClip_setThreshold(threshold, knee, ratio);
);

function StereoCompressor_setGain(gain, dry_mix, in_gain)
(
  this.comp1.gain = gain;
  this.comp1.dry_mix_k = dry_mix;
  this.comp1.in_gain = in_gain;

  this.comp2.gain = gain;
  this.comp2.dry_mix_k = dry_mix;
  this.comp2.in_gain = in_gain;
);

function StereoCompressor_setSat(threshold)
(
  // setup saturation
  this.comp1.saturator.Saturator_setThreshold(threshold);
  this.comp2.saturator.Saturator_setThreshold(threshold);
);

function StereoCompressor_setStereoMode(sl)
(
  this.stereo_mode = sl;

  // bypass saturator in S and M/S mode (avoid stereo image damage)
  this.comp1.use_saturator = ((sl != SL_S && sl != SL_MS) && this.use_sat);
  this.comp2.use_saturator = this.comp1.use_saturator;
);

function StereoCompressor_setUseSat(use)
(
  this.use_sat = use;

  // refresh saturator settings
  this.StereoCompressor_setStereoMode(this.stereo_mode);
);

function StereoCompressor_processSample(x1, x2, sc1, sc2) local(xm, xs, ym, ys, sc_m, sc_s, env1, env2, env)
(
  (this.stereo_mode == SL_MONO) ? (

    this.y1 = this.comp1.ChannelCompressor_processSample(x1, sc1);
    this.y2 = this.y1;

    this.gr = this.comp1.gr;

  ) : (this.stereo_mode == SL_2MONO) ? (

    this.y1 = this.comp1.ChannelCompressor_processSample(x1, sc1);
    this.y2 = this.comp2.ChannelCompressor_processSample(x2, sc2);

    this.gr = min(this.comp1.gr, this.comp2.gr);

  ) : (this.stereo_mode == SL_M) ? (

    xm = (x1 + x2) / 2.0;
    xs = (x1 - x2) / 2.0;

    sc_m = (sc1 + sc2) / 2.0;

    ym = this.comp1.ChannelCompressor_processSample(xm, sc_m);
    ys = xs;

    this.y1 = ym + ys;
    this.y2 = ym - ys;

    this.gr = this.comp1.gr;

  ) : (this.stereo_mode == SL_S) ? (

    xm = (x1 + x2) / 2.0;
    xs = (x1 - x2) / 2.0;

    sc_s = (sc1 - sc2) / 2.0;

    ym = xm;
    ys = this.comp1.ChannelCompressor_processSample(xs, sc_s);

    this.y1 = ym + ys;
    this.y2 = ym - ys;

    this.gr = this.comp1.gr;

  ) : (this.stereo_mode == SL_STEREO) ? (

    env1 = this.comp1.ChannelCompressor_preprocessSample(sc1);
    env2 = this.comp2.ChannelCompressor_preprocessSample(sc2);

    env = (env1 + env2) / 2.0;

    this.y1 = this.comp1.ChannelCompressor_postprocessSample(x1, env);
    this.y2 = this.comp2.ChannelCompressor_postprocessSample(x2, env);

    this.gr = min(this.comp1.gr, this.comp2.gr);

  ) : (this.stereo_mode == SL_MS) ? (

    sc_m = (sc1 + sc2) / 2.0;
    sc_s = (sc1 - sc2) / 2.0;

    env1 = this.comp1.ChannelCompressor_preprocessSample(sc_m);
    env2 = this.comp2.ChannelCompressor_preprocessSample(sc_s);

    env = max(env1, env2);

    xm = (x1 + x2) / 2.0;
    xs = (x1 - x2) / 2.0;

    ym = this.comp1.ChannelCompressor_postprocessSample(xm, env);
    ys = this.comp2.ChannelCompressor_postprocessSample(xs, env);

    // as saturator is off (see setStereoMode) saturate stereo output now

    this.y1 = this.comp1.saturator.Saturator_processSample(ym + ys);
    this.y2 = this.comp2.saturator.Saturator_processSample(ym - ys);

    this.gr = min(this.comp1.gr, this.comp2.gr);

  );
);

function StereoCompressor_reset()
(
  this.comp1.ChannelCompressor_reset();
  this.comp2.ChannelCompressor_reset();
);

// continue @init:

(global_init == 0) ? (

  // init memory buffers:

  __memory_Index__ = 0;

  EnvelopeClip_init();

  global_init = 1;
);

compressor.StereoCompressor_reset();

@slider

param_Input = DB_TO_K(slider1);
param_SCFilterFreq = slider2;
param_SCFilterOn = slider3;
param_Threshold = DB_TO_K(slider4);
param_Ratio = slider5;
param_Knee = slider6;
param_Attack = slider7 / 1000.0;
param_AttackMode = slider8;
param_Release = slider9 / 1000.0;
param_SatOn = slider10;
param_SatDrive = slider11;
param_Makeup = DB_TO_K(slider12);
param_DryMix = slider13 / 100.0;
param_StereoMode = slider14;
param_Bypass = slider15;
param_Sidechain = slider16;

compressor.StereoCompressor_setEnvelope(
  param_Attack,
  param_Release,
  param_SCFilterOn ? param_SCFilterFreq : 0,
  param_AttackMode == 0);

compressor.StereoCompressor_setEnvelopeK(param_Threshold, param_Knee, param_Ratio);

compressor.StereoCompressor_setSat(DB_TO_K(12.0 - param_SatDrive));
compressor.StereoCompressor_setUseSat(param_SatOn);

compressor.StereoCompressor_setGain(param_Makeup, param_DryMix, param_Input);

compressor.StereoCompressor_setStereoMode(param_StereoMode);

@block

ext_gr_meter = K_TO_DB(hold_max_gr);

hold_max_gr = 1.0;

@sample

(!param_Bypass) ? (

  (!param_Sidechain) ?
    compressor.StereoCompressor_processSample(spl0, spl1, spl0, spl1) :
    compressor.StereoCompressor_processSample(spl0, spl1, spl2, spl3);
    
  spl0 = compressor.y1;
  spl1 = compressor.y2;
);

hold_max_gr = min(hold_max_gr, compressor.gr);

