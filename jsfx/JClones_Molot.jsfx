desc:       JClones_Molot
version:    1.0.0
author:     JClones
tags:       compressor
link:       https://github.com/JClones/JSFXClones
screenshot: https://github.com/JClones/JSFXClones/blob/master/assets/screenshots/JClones_Molot.png
about:
    # JClones_Molot
    JClones_Molot is a clone of colorful, character compressor from the late 2000s / early 2010s

    ## Main Parameters

    **Input:** Controls how hard the signal hits the compressor.

    **SC Filter Freq.:** Reduces low-frequency influence on compression.

    **SC Filter:** Enables or disables the sidechain filter.

    **Threshold:** Sets the level where compression begins.

    **Ratio:** Determines how strongly the signal is compressed after crossing threshold.

    **Knee:** Controls how gradually compression starts. Soft knee (smaller values): Smoother, more musical onset. Hard knee (larger values): More aggressive, punchy. In Molot, Knee has a very audible effect - more than in many compressors.

    **Attack:** Controls how fast compression engages.

    **Attack Mode:** Switches between two detection behaviors.

    **Alpha:** Smoother, more “musical”, less aggressive.

    **Sigma:** More reactive, punchier, stronger transient shaping.

    **Release:** Controls how fast compression recovers.

    **Sat:** Enables or disables the saturation.

    **Sat Drive:** Increasing the level introduces harmonics.

    **Makeup:** Adjusts the final level after compression.

    **Dry Mix:** Blend compressed and original signal.

    **Mode:** Sets stereo processing mode.

    **Bypass:** Switches the processing off.

    **Sidechain:** Switches between internal and external sidechain.

    Note: JClones version of Molot doesn't include limiter, EQ and oversampling stages present in the original plugin.

slider1:0<-12,12,0.1>Input, dB
slider2:120<40,260,1>SC Filter Freq, Hz
slider3:1<0,1,1{Off,On}>SC Filter
slider4:-10<-40,0,0.1>Threshold, dB
slider5:4.0<1.1,10.9,0.1>Ratio, :1
slider6:1.0<0.0,1.0,0.01>Knee
slider7:10<1,100,0.1>Attack, ms
slider8:1<0,1,1{Alpha,Sigma}>Attack Mode
slider9:110<50,1000,0.1>Release, ms
slider10:1<0,1,1{Off,On}>Sat
slider11:6<-12,12,0.1>Sat Drive, dB
slider12:0<-12,12,0.1>Makeup, dB
slider13:0<0,100,0.1>Dry Mix, %
slider14:5<0,5,1{Mono,Dual Mono,M,S,MS,Stereo}>Mode
slider15:0<0,1,1{Off,On}>Bypass
slider16:0<0,1,1{Int SC.,Ext SC.}>Sidechain

in_pin:left input
in_pin:right input
in_pin:sidechain left input
in_pin:sidechain right input
out_pin:left output
out_pin:right output

@init

ext_gr_meter = 0.0;

// for allocator
function allocate(size) local(result)
(
  result = __memory_Index__;
  __memory_Index__ += size;
  result;
);

function DB_TO_K(x)
(
  10 ^ (x / 20)
);

function K_TO_DB(x)
(
  20 * log10(x);
);

M_SQRT2 = sqrt(2.0);
M_SQRT1_2 = M_SQRT2 / 2.0;

/*
 * Filter2 - digital second order filter:
 * X(z) = (a0 + a1*z^-1 + a2*z^-2) / (1 - b1*z^-1 - b2*z^-2)
 */
 
function Filter2_reset()
(
  this.x1 = 0;
  this.x2 = 0;
  this.y1 = 0;
  this.y2 = 0;
);

function Filter2_reset_v(val)
(
  this.x1 = val;
  this.x2 = val;
  this.y1 = val;
  this.y2 = val;
);

function Filter2_processSample(x0) local(y0)
(
  y0 = x0 * this.a0 + this.x1 * this.a1 + this.x2 * this.a2 +
    this.y1 * this.b1 + this.y2 * this.b2;
    
  // shift history
  this.x2 = this.x1;
  this.x1 = x0;
  
  this.y2 = this.y1;
  this.y1 = y0;
  
  y0;
);

function Filter2_LPFilter2(freq_k, Q) local(w0, KK, KK2, a0, a1, a2, b0, b1, b2)
(
  w0 = freq_k * 2.0 * $pi;
  KK = 1.0 / tan(w0 / 2.0);
  KK2 = KK * KK;

  a0 = 1.0;
  a1 = 2.0;
  a2 = 1.0;
  b0 = KK2 + KK / Q + 1.0;
  b1 = 2.0 * (1.0 - KK2);
  b2 = KK2 - KK / Q + 1.0;

  this.a0 = a0 / b0;
  this.a1 = a1 / b0;
  this.a2 = a2 / b0;
  this.b1 = -b1 / b0;
  this.b2 = -b2 / b0;
);

function Filter2_HPFilter2(freq_k, Q) local(omega0, alpha)
(
  /*
   * http://www.musicdsp.org/files/Audio-EQ-Cookbook.txt
   */

  omega0 = freq_k * 2.0 * $pi;
  alpha = sin(omega0) / (2.0 * Q);

  this.a0 = ((1.0 + cos(omega0)) / 2.0) / (1.0 + alpha);
  this.a1 = -(1.0 + cos(omega0)) / (1.0 + alpha);
  this.a2 = ((1.0 + cos(omega0)) / 2.0) / (1.0 + alpha);

  this.b1 = -(-2.0 * cos(omega0)) / (1.0 + alpha);
  this.b2 = -(1.0 - alpha) / (1.0 + alpha);
);

function Filter2_LSFilter2(freq_k, Q, A) local(alpha, w0, a0, a1, a2, b0, b1, b2)
(
  /*
   * http://www.musicdsp.org/files/Audio-EQ-Cookbook.txt
   */

  A = sqrt(A);        // 10^(Adb / 40) e.g. Adb / 2.

  w0 = freq_k * 2.0 * $pi;
  alpha = sin(w0) / (2.0 * Q);

  a0 = A * ((A + 1.0) - (A - 1.0) * cos(w0) + 2.0 * sqrt(A) * alpha);
  a1 = 2.0 * A * ((A - 1.0) - (A + 1.0) * cos(w0));
  a2 = A * ((A + 1.0) - (A - 1.0) * cos(w0) - 2.0 * sqrt(A) * alpha);

  b0 = (A + 1.0) + (A - 1.0) * cos(w0) + 2.0 * sqrt(A) * alpha;
  b1 = -2.0 * ((A - 1.0) + (A + 1.0) * cos(w0));
  b2 = (A + 1.0) + (A - 1.0) * cos(w0) - 2.0 * sqrt(A) * alpha;

  this.a0 = a0 / b0;
  this.a1 = a1 / b0;
  this.a2 = a2 / b0;
  
  this.b1 = -b1 / b0;
  this.b2 = -b2 / b0;
);

/*
 * LowShelfPhon80
 */

// for Q=0.199 got -3db at 262 hZ
function LowShelfPhon80_get_Q_from_hz(x) local(min_freq_hz, ff, ff2, Q)
(
  min_freq_hz = 23.756;

  (x < min_freq_hz) ? (
    x = min_freq_hz;
  );

  // solved H(x / 35.15, Q)^2 = -3 db equation

  ff = x / 35.15;
  ff2 = ff * ff;

  Q = 1.0 / sqrt((M_SQRT2 - 1.0) * ff2 + 2.0 - 1.0 / ff2);

  Q;
);

function LowShelfPhon80_setFilter(freq_hz)
(
  // 35.15 Hz; Q=0.199; filter calculated for 8 points (20..90 Hz) from phon80 ISO226:2003
  this.flt1.Filter2_HPFilter2(35.15 / srate, LowShelfPhon80_get_Q_from_hz(freq_hz));
  this.flt2.Filter2_HPFilter2(35.15 / srate, LowShelfPhon80_get_Q_from_hz(freq_hz));
);

function LowShelfPhon80_processSample(x)
(
  this.flt2.Filter2_processSample(this.flt1.Filter2_processSample(x));
);

function LowShelfPhon80_reset()
(
  this.flt1.Filter2_reset();
  this.flt2.Filter2_reset();
);

/*
 * ARFilter
 */

function ARFilter_setAttackRelease(attack_freq_k, release_freq_k, signal_freq_k, sharp_mode)
(
  this.diode_lpf.Filter2_LPFilter2(!sharp_mode ? max(attack_freq_k, release_freq_k) : signal_freq_k, M_SQRT1_2);

  this.fa = 1.0 / (1.0 / (attack_freq_k * 2.0 * $pi) + 1.0);
  this.fr = 1.0 / (1.0 / (release_freq_k * 2.0 * $pi) + 1.0);

  // diode stuff
  this.diode_xx = 0.025;

  this.diode_ax7 = -3432.0 / pow(this.diode_xx, 15.0);
  this.diode_ax6 = 25740.0 / pow(this.diode_xx, 14.0);
  this.diode_ax5 = -83160.0 / pow(this.diode_xx, 13.0);
  this.diode_ax4 = 150150 / pow(this.diode_xx, 12.0);
  this.diode_ax3 = -163800.0 / pow(this.diode_xx, 11.0);
  this.diode_ax2 = 108108.0 / pow(this.diode_xx, 10.0);
  this.diode_ax1 = -40040.0 / pow(this.diode_xx, 9.0);
  this.diode_ax0 = 6435.0 / pow(this.diode_xx, 8.0);
);

function ARFilter_diode(x) local(x2, x4, x8, x12, y)
(
  /*
   * this approximation sounds very good
   */

  (x < 0.0) ? (
    y = 0.0;
  ) : ( x > this.diode_xx) ? (
    y = x;
  ) : (
    // spline 2 curves
    x2 = x * x;
    x4 = x2 * x2;
    x8 = x4 * x4;
    x12 = x8 * x4;

    // this.diode_ax0 for x^9
    y = x8 * x * this.diode_ax0 + x8 * x2 * this.diode_ax1 + x8 * x2 * x * this.diode_ax2 +
      x12 * this.diode_ax3 + x12 * x * this.diode_ax4 + x12 * x2 * this.diode_ax5 +
      x12 * x2 * x * this.diode_ax6 + x12 * x4 * this.diode_ax7;
  );

  y;
);

function ARFilter_processSample(x) local(y)
(
  y = (this.s += this.fa * (this.ARFilter_diode(x - this.s)) +
    this.fr * (x - this.s));

  // alternative way: use second diode for release fr * ( -ARFilter_diode(this.s - x) ) but don't needed

  y = this.diode_lpf.Filter2_processSample(y);

  y;
);

function ARFilter_reset(reset_to_1)
(
  this.diode_lpf.Filter2_reset_v(reset_to_1 ? 1.0 : 0.0);
  this.s = 0;
);

/*
 * AREnvelope
 */

function AREnvelope_setAttackRelease(attack_freq_k, release_freq_k, signal_freq_k, sharp_mode)
(
  this.fabs_lpf.Filter2_LPFilter2(signal_freq_k, M_SQRT1_2);
  this.filter.ARFilter_setAttackRelease(attack_freq_k, release_freq_k, signal_freq_k, sharp_mode);
);


function AREnvelope_sec_to_freq_k(sec) local(freq)
(
  (sec > 0.0) ? (
    freq = 1.0 / sec;
  ) : (
    freq = srate / (2.0 * $pi);
  );

  freq / srate;
);

function AREnvelope_tau_to_freq_k(sec)
(
  AREnvelope_sec_to_freq_k(sec) / (2.0 * $pi);
);

function AREnvelope_processSampleAC(x) local(y1, y2, y3)
(
  y1 = abs(x);             // get x: 0..1
  y2 = this.fabs_lpf.Filter2_processSample(y1);  // try to remove abs() partials
  y3 = this.filter.ARFilter_processSample(y2);  // follow it

  y3;
);

function AREnvelope_processSampleDC(x)
(
  this.filter.ARFilter_processSample(x);   // follow it
);

function AREnvelope_reset(reset_to_1)
(
  this.fabs_lpf.Filter2_reset();
  this.filter.ARFilter_reset(reset_to_1);
);

/*
 * EnvelopeClip
 */

function EnvelopeClip_init() local(i, d)
(
  // rows
  M_SQRT_k = allocate(99);

  // columns
  i = 0;

  loop(99,
    M_SQRT_k[i] = allocate(10);
    i += 1;
  );

  d = M_SQRT_k;

